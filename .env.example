# VibeCMS Configuration
# Copy to .env and fill in values

# Server
PORT=8080
APP_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=vibecms
DB_PASSWORD=vibecms_secret
DB_NAME=vibecms
DB_SSLMODE=disable

# Auth
SESSION_SECRET=change-me-to-a-random-64-char-string
SESSION_EXPIRY_HOURS=24

# Monitoring API
MONITOR_BEARER_TOKEN=change-me-to-a-random-token

# Storage (local or s3)
STORAGE_DRIVER=local
STORAGE_PATH=./storage

# S3 (if STORAGE_DRIVER=s3)
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=

# AI Provider (openai or anthropic)
AI_PROVIDER=
AI_API_KEY=

# Mail (resend or smtp)
MAIL_PROVIDER=
RESEND_API_KEY=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
