# Themes — only the three reference themes ship in this repo. Any other theme
# directory (squilla, third-party, scratch builds) lives in its own repo and
# is gitignored here. To add another built-in theme, add an exception below.
themes/*/
!themes/default/
!themes/hello-vietnam/
!themes/curriculum-vitae/

# Git worktrees for isolated feature development
.worktrees/

# Operator-installed themes and extensions — bind-mounted at /app/data in
# docker-compose. Per-deploy state, never committed.
data/

# Local backup of admin-ui sources, never committed.
admin-ui/src.zip
