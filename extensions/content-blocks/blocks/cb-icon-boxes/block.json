{
  "slug": "cb-icon-boxes",
  "label": "Icon Boxes",
  "icon": "box",
  "description": "Compact icon boxes for quick feature scanning. Smaller than feature cards. Use for tech stacks, benefit lists, amenities. Layout: 3-6 column grid of small boxes with centered icon, bold title, 1-2 line description. Three style variants: filled/outlined/minimal.",
  "field_schema": [
    {
      "label": "Section Heading",
      "type": "text",
      "required": false,
      "key": "heading"
    },
    {
      "label": "Items",
      "type": "repeater",
      "sub_fields": [
        {
          "label": "Icon (Lucide icon name, e.g. rocket, shield, code, users)",
          "type": "text",
          "required": true,
          "key": "icon"
        },
        {
          "label": "Title",
          "type": "text",
          "required": true,
          "key": "title"
        },
        {
          "label": "Description",
          "type": "text",
          "required": false,
          "key": "description"
        }
      ],
      "key": "items"
    },
    {
      "label": "Columns",
      "type": "select",
      "options": [
        "3",
        "4",
        "5",
        "6"
      ],
      "default": "4",
      "key": "columns"
    },
    {
      "label": "Style",
      "type": "select",
      "options": [
        "filled",
        "outlined",
        "minimal"
      ],
      "default": "filled",
      "key": "style"
    }
  ],
