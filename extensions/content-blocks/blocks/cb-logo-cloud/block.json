    {
      "name": "heading",
      "label": "Heading",
      "type": "text",
      "required": false
    },
    {
      "name": "style",
      "label": "Logo Style",
      "type": "select",
      "options": [
        { "label": "Grayscale", "value": "grayscale" },
        { "label": "Color", "value": "color" },
        { "label": "Monochrome", "value": "monochrome" }
      ],
      "default": "grayscale"
    },
    {
      "name": "logos",
      "label": "Logos",
      "type": "repeater",
      "sub_fields": [
        {
          "name": "image",
          "label": "Logo Image",
          "type": "image",
          "required": true
        },
        {
          "name": "name",
          "label": "Company Name",
          "type": "text",
          "required": true
        },
        {
          "name": "url",
          "label": "Website URL",
          "type": "text",
          "required": false
        }
      ]
    }
  ],
