{
  "slug": "cb-logo-cloud",
  "label": "Logo Cloud",
  "icon": "building",
  "description": "A client or partner logo grid for trust signals. Shows logos in grayscale that gain color on hover. Use for 'Trusted by' sections, partner showcases. Layout: centered section with heading, responsive grid of logos with consistent sizing, grayscale filter with hover color transition.",
  "field_schema": [
    {
      "label": "Heading",
      "type": "text",
      "required": false,
      "key": "heading"
    },
    {
      "label": "Logo Style",
      "type": "select",
      "options": [
        {
          "label": "Grayscale",
          "value": "grayscale"
        },
        {
          "label": "Color",
          "value": "color"
        },
        {
          "label": "Monochrome",
          "value": "monochrome"
        }
      ],
      "default": "grayscale",
      "key": "style"
    },
    {
      "label": "Logos",
      "type": "repeater",
      "sub_fields": [
        {
          "label": "Logo Image",
          "type": "image",
          "required": true,
          "key": "image"
        },
        {
          "label": "Company Name",
          "type": "text",
          "required": true,
          "key": "name"
        },
        {
          "label": "Website URL",
          "type": "text",
          "required": false,
          "key": "url"
        }
      ],
      "key": "logos"
    }
  ],
