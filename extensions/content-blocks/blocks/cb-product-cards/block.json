{
  "slug": "cb-product-cards",
  "label": "Product Cards",
  "icon": "shopping-bag",
  "description": "Product showcase cards with image, name, price, and CTA button. Use for e-commerce product listings, course catalogs, downloadable showcases. Layout: 2-4 column card grid with product image (hover zoom), name, optional category tag, price with optional strikethrough original, and CTA button.",
  "field_schema": [
    {
      "label": "Heading",
      "type": "text",
      "required": false,
      "key": "heading"
    },
    {
      "label": "Columns",
      "type": "select",
      "options": [
        {
          "label": "2 Columns",
          "value": "2"
        },
        {
          "label": "3 Columns",
          "value": "3"
        },
        {
          "label": "4 Columns",
          "value": "4"
        }
      ],
      "default": "3",
      "key": "columns"
    },
    {
      "label": "Products",
      "type": "repeater",
      "sub_fields": [
        {
          "label": "Product Image",
          "type": "image",
          "required": true,
          "key": "image"
        },
        {
          "label": "Product Name",
          "type": "text",
          "required": true,
          "key": "name"
        },
        {
          "label": "Category",
          "type": "text",
          "required": false,
          "key": "category"
        },
        {
          "label": "Price",
          "type": "text",
          "required": true,
          "key": "price"
        },
        {
          "label": "Original Price (strikethrough)",
          "type": "text",
          "required": false,
          "key": "original_price"
        },
        {
          "label": "Button Text",
          "type": "text",
          "default": "Buy Now",
          "key": "button_text"
        },
        {
          "label": "Button URL",
          "type": "text",
          "required": true,
          "key": "button_url"
        }
      ],
      "key": "products"
    }
  ],
