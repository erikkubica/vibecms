{
  "slug": "cb-recent-posts",
  "label": "Recent Posts",
  "icon": "file-text",
  "description": "A dynamic recent posts block that fetches and displays the latest content from the CMS via AJAX. Shows post cards with featured image, title, excerpt, date, and link. Use for blog sidebars, homepage sections, or news feeds. Layout: responsive card grid or list view showing latest posts, auto-loaded on page view.",
  "field_schema": [
    {
      "label": "Heading",
      "type": "text",
      "key": "heading"
    },
    {
      "label": "Content Type",
      "type": "node_type_select",
      "default": "post",
      "key": "node_type"
    },
    {
      "label": "Number of Posts",
      "type": "number",
      "default": 6,
      "key": "count"
    },
    {
      "label": "Layout",
      "type": "select",
      "options": [
        "grid",
        "list"
      ],
      "default": "grid",
      "key": "layout"
    },
    {
      "label": "Columns",
      "type": "select",
      "options": [
        "2",
        "3",
        "4"
      ],
      "default": "3",
      "key": "columns"
    },
    {
      "label": "Show Image",
      "type": "toggle",
      "default": true,
      "key": "show_image"
    },
    {
      "label": "Show Excerpt",
      "type": "toggle",
      "default": true,
      "key": "show_excerpt"
    },
    {
      "label": "Show Date",
      "type": "toggle",
      "default": true,
      "key": "show_date"
    },
    {
      "label": "Link Text",
      "type": "text",
      "default": "Read More",
      "key": "link_text"
    }
  ],
  "test_data": {
    "heading": "Latest Articles",
    "node_type": "post",
    "count": 6,
    "layout": "grid",
    "columns": "3",
    "show_image": true,
    "show_excerpt": true,
    "show_date": true,
    "link_text": "Read More"
  }
}
