{
  "slug": "cb-social-share",
  "label": "Social Share",
  "icon": "share-2",
  "description": "A social media sharing bar with buttons for Twitter/X, Facebook, LinkedIn, and email. Generates share URLs automatically from the current page URL and title. Use at the end of blog posts, articles, or any shareable content. Layout: horizontal row of styled share buttons with optional share count label.",
  "field_schema": [
    {
      "label": "Heading",
      "type": "text",
      "key": "heading"
    },
    {
      "label": "Show Twitter/X",
      "type": "toggle",
      "default": true,
      "key": "show_twitter"
    },
    {
      "label": "Show Facebook",
      "type": "toggle",
      "default": true,
      "key": "show_facebook"
    },
    {
      "label": "Show LinkedIn",
      "type": "toggle",
      "default": true,
      "key": "show_linkedin"
    },
    {
      "label": "Show Email",
      "type": "toggle",
      "default": true,
      "key": "show_email"
    },
    {
      "label": "Show Copy Link",
      "type": "toggle",
      "default": true,
      "key": "show_copy_link"
    },
    {
      "label": "Style",
      "type": "select",
      "options": [
        "icons",
        "buttons",
        "minimal"
      ],
      "default": "buttons",
      "key": "style"
    },
    {
      "label": "Alignment",
      "type": "select",
      "options": [
        "left",
        "center",
        "right"
      ],
      "default": "center",
      "key": "alignment"
    }
  ],
  "test_data": {
    "heading": "Share this article",
    "show_twitter": true,
    "show_facebook": true,
    "show_linkedin": true,
    "show_email": true,
    "show_copy_link": true,
    "style": "buttons",
    "alignment": "center"
  }
}
