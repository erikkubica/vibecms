    },
    {
      "name": "show_facebook",
      "label": "Show Facebook",
      "type": "toggle",
      "default": true
    },
    {
      "name": "show_linkedin",
      "label": "Show LinkedIn",
      "type": "toggle",
      "default": true
    },
    {
      "name": "show_email",
      "label": "Show Email",
      "type": "toggle",
      "default": true
    },
    {
      "name": "show_copy_link",
      "label": "Show Copy Link",
      "type": "toggle",
      "default": true
    },
    {
