      "label": "Style",
      "type": "select",
      "options": ["icons", "buttons", "minimal"],
      "default": "buttons"
    },
    {
      "name": "alignment",
      "label": "Alignment",
      "type": "select",
      "options": ["left", "center", "right"],
      "default": "center"
