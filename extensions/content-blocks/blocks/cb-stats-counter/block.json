{
  "slug": "cb-stats-counter",
  "label": "Stats Counter",
  "icon": "trending-up",
  "description": "Animated number counters that count up from zero when scrolled into view. Use for company statistics, achievement metrics. Layout: 3-4 large numbers in a row with labels, optional prefix/suffix ($, +, %). Intersection Observer animation.",
  "field_schema": [
    {
      "label": "Section Heading",
      "type": "text",
      "required": false,
      "key": "heading"
    },
    {
      "label": "Stats",
      "type": "repeater",
      "sub_fields": [
        {
          "label": "Icon (Lucide icon name, e.g. rocket, shield, code, users)",
          "type": "text",
          "required": false,
          "key": "icon"
        },
        {
          "label": "Number",
          "type": "text",
          "required": true,
          "key": "number"
        },
        {
          "label": "Label",
          "type": "text",
          "required": true,
          "key": "label"
        },
        {
          "label": "Prefix",
          "type": "text",
          "required": false,
          "key": "prefix"
        },
        {
          "label": "Suffix",
          "type": "text",
          "required": false,
          "key": "suffix"
        }
      ],
      "key": "stats"
    },
    {
      "label": "Style",
      "type": "select",
      "options": [
        "light",
        "dark",
        "accent"
      ],
      "default": "light",
      "key": "style"
    }
  ],
  "test_data": {
