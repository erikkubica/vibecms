{
    "name": "Email Manager",
    "slug": "email-manager",
    "version": "1.0.0",
    "author": "VibeCMS",
    "description": "Manage email templates, rules, delivery logs, and provider settings.",
    "provides": ["email-management"],
    "capabilities": [
        "data:read",
        "data:write",
        "settings:read",
        "settings:write",
        "events:subscribe",
        "log:write"
    ],
    "data_owned_tables": [
        "email_templates",
        "email_rules",
        "email_logs",
        "email_layouts"
    ],
    "plugins": [
        {
            "binary": "bin/email-manager",
            "events": []
        }
    ],
    "admin_ui": {
        "entry": "admin-ui/dist/index.js",
        "routes": [
            {"path": "/templates", "component": "EmailTemplates"},
            {"path": "/templates/new", "component": "EmailTemplateEditor"},
            {"path": "/templates/:id", "component": "EmailTemplateEditor"},
            {"path": "/layouts", "component": "EmailBaseLayout"},
            {"path": "/rules", "component": "EmailRules"},
            {"path": "/rules/new", "component": "EmailRuleEditor"},
            {"path": "/rules/:id", "component": "EmailRuleEditor"},
            {"path": "/logs", "component": "EmailLogs"},
            {"path": "/settings", "component": "EmailSettings"}
        ],
        "menu": {
            "label": "Email",
            "icon": "Mail",
            "position": "6",
            "section": "settings",
            "children": [
                {"label": "Templates", "route": "/admin/ext/email-manager/templates", "icon": "LayoutTemplate"},
                {"label": "Layouts", "route": "/admin/ext/email-manager/layouts", "icon": "Layout"},
                {"label": "Rules", "route": "/admin/ext/email-manager/rules", "icon": "Gavel"},
                {"label": "Logs", "route": "/admin/ext/email-manager/logs", "icon": "ScrollText"},
                {"label": "Settings", "route": "/admin/ext/email-manager/settings", "icon": "Settings"}
            ]
        }
    }
}
