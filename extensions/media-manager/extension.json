{
    "name": "Media Manager",
    "slug": "media-manager",
    "version": "1.0.0",
    "author": "VibeCMS",
    "description": "Upload, organize, and manage media files. Supports images, documents, and other file types.",
    "provides": ["media"],
    "capabilities": [
        "media:read",
        "media:write",
        "media:delete",
        "data:read",
        "data:write",
        "files:write",
        "files:delete",
        "settings:read",
        "log:write"
    ],
    "plugins": [
        {
            "binary": "bin/media-manager",
            "events": []
        }
    ],
    "admin_ui": {
        "entry": "admin-ui/dist/index.js",
        "routes": [
            {"path": "/", "component": "MediaLibrary"}
        ],
        "menu": {
            "label": "Media",
            "icon": "Image",
            "position": "3"
        }
    }
}
