// theme.tengo — Curriculum Vitae theme entry point.
// Single-page CV. Seeds: cv.* settings, main-nav menu (anchor links), and a
// home page populated with cv-* blocks.

log := import("core/log")
nodes := import("core/nodes")
settings := import("core/settings")
menus := import("core/menus")

log.info("Curriculum Vitae theme initializing...")

// ─── Site Settings (cv.* namespace) ──────────────────────────
seed_setting := func(key, value) {
    existing := settings.get(key)
    if existing == "" || is_error(existing) {
        settings.set(key, value)
    }
}

seed_setting("cv.brand",           "erik-kubica.dev")
seed_setting("cv.nav_cta_label",   "available")
seed_setting("cv.nav_cta_url",     "mailto:erik.kubica@gmail.com")
seed_setting("cv.accent",          "#DA251D")
seed_setting("cv.copyright_year",  "2026")
seed_setting("cv.copyright_owner", "Erik Kubica")
seed_setting("cv.footer_line",     "built with too much coffee · zero shortcuts")
log.info("Curriculum Vitae: cv.* settings seeded")

// ─── Page Seeding ─────────────────────────────────────────────
// Single-page CV theme: home page is the entire site. We seed it on first
// activation only — if the page already exists, editor changes are preserved
// (re-activating the theme must not blow away user content). For a fresh
// reset, delete the home page and re-activate, or use the future
// "Reload content from theme" action.

cv_blocks := [
            { type: "cv-hero", fields: {
                name_tag: "// available · 25 €/h · b2b",
                name: "Erik Kubica",
                sub: "Senior full-stack dev who spent a decade making PHP behave — now wiring AI, MCP and agents on top of it.",
                side_items: [
                    { label: "loc",   value: "Vietnam · Slovakia (EU)", url: "" },
                    { label: "hrs",   value: "SEA / EU timezones",      url: "" },
                    { label: "since", value: "10+ yrs · 140+ projects", url: "" },
                    { label: "mail",  value: "erik.kubica@gmail.com",   url: "mailto:erik.kubica@gmail.com" },
                    { label: "tel",   value: "+421 908 766 133",        url: "https://wa.me/421908766133" }
                ],
                strip_items: [
                    { count: "10+",  label: "years" },
                    { count: "140+", label: "projects shipped" },
                    { count: "130+", label: "WordPress sites" },
                    { count: "7",    label: "React apps" },
                    { count: "4",    label: "Symfony APIs" },
                    { count: "0",    label: "shortcuts" }
                ]
            } },
            { type: "cv-about", fields: {
                section_id: "about",
                eyebrow: "01 · about",
                heading: "Builds things that don't fall over six months later.",
                lede: "Ten-plus years of writing the kind of code you can come back to. PHP / Symfony / WordPress at the core, React and Next.js on top, and for the last while: a serious push into AI — MCP servers, agent workflows, retrieval, the works.",
                day_job_label: "day job",
                day_job_text: "Bridging real business stuff with real engineering. I came out of commerce, so I get why the deadline matters and why the invoice has to be right. Then I write the API.",
                client_label: "note for clients",
                client_text: "Based in Vietnam, but a fully registered Slovak (EU) freelance contractor with EU tax residency. Standard B2B invoicing, no weirdness. Available across SEA and EU hours.",
                off_label: "off-hours",
                off_items: [
                    { icon: "laptop", text: "Vibecoding until 4 a.m. — me, the cursor, and one too many tabs open." },
                    { icon: "beer",   text: "Bia Hà Nội on the little blue stool, watching scooters honk past." },
                    { icon: "tv",     text: "Anime, Star Trek, and arguing about which Captain is best (it's Picard)." }
                ]
            } },
            { type: "cv-now", fields: {
                section_id: "now",
                eyebrow: "02 · now",
                heading: "AI-native, on top of a stack that already works.",
                sub: "The last decade was PHP, Symfony, WordPress, React. The next one is all of that <em>plus</em> agents, MCP and LLMs doing real work — not demos.",
                items: [
                    { label: "MCP servers",     body: "Build and ship Model Context Protocol servers that plug company data, internal APIs and tooling into Claude / Cursor / agent runtimes. The bridge between LLMs and the messy real world.", tags: "MCP, TypeScript, Python, Claude" },
                    { label: "Agent workflows", body: "Multi-step agents for support, ops, content and code review. Tool use, guardrails, evals, human-in-the-loop. Boring on purpose — they have to actually work on Monday morning.", tags: "Agents, Tool use, Evals" },
                    { label: "RAG + search",    body: "Hybrid retrieval over PDFs, ticketing systems, CRMs and 130+ legacy WordPress installs. Postgres + pgvector when sane, dedicated vector DBs when not.", tags: "pgvector, Embeddings, Hybrid search" },
                    { label: "LLM in PHP",      body: "Yes, really. Symfony + LLM gateways, streaming responses into WooCommerce, content pipelines for WordPress at scale. AI on top of the stack you already paid for.", tags: "Symfony, WordPress, OpenAI, Anthropic" }
                ],
                side_intro: "// what this looks like in practice",
                side_items: [
                    { text: "An MCP server that lets Claude hit your Symfony admin API directly." },
                    { text: "A support agent that reads tickets, drafts replies, tags them, and shuts up when it isn't sure." },
                    { text: "A WordPress plugin that uses an LLM for content ops without leaking your data." },
                    { text: "RAG over a decade of project docs so the next dev doesn't start from zero." }
                ]
            } },
            { type: "cv-stack", fields: {
                section_id: "stack",
                eyebrow: "03 · stack",
                heading: "What I actually use.",
                sub: "Not every logo in existence — just the things I reach for on a Tuesday.",
                groups: [
                    { name: "AI / Agents",     rows: "MCP || Building servers + clients\nClaude / GPT / Gemini || Production\nLangGraph / custom orchestration || Production\npgvector / Qdrant || Production\nCursor / Claude Code || Daily driver" },
                    { name: "Backend",         rows: "PHP || 13+ yrs · Expert\nSymfony || 8+ yrs · Advanced\nNode.js || Intermediate\nJava / Spring Boot || Intermediate" },
                    { name: "Frontend",        rows: "JavaScript || 10+ yrs · Expert\nReact || 5+ yrs · Advanced\nNext.js || 3+ yrs · Advanced\nTypeScript || Advanced" },
                    { name: "CMS / Commerce",  rows: "WordPress || 130+ sites · Expert\nWooCommerce || Advanced\nMagento 1.9 & 2 || 3 stores" },
                    { name: "Data / DevOps",   rows: "MySQL || 10+ yrs\nPostgreSQL || Advanced\nDocker || Daily\nKubernetes || Intermediate" },
                    { name: "Testing / QA",    rows: "Jest || Advanced\nPHPUnit || Advanced\nStorybook || Intermediate\nTDD || Advanced" }
                ],
                lang_label: "languages",
                languages: [
                    { code: "SK", level: "native" },
                    { code: "EN", level: "fluent" },
                    { code: "HU", level: "fluent" },
                    { code: "CZ", level: "fluent" }
                ]
            } },
            { type: "cv-experience", fields: {
                section_id: "xp",
                eyebrow: "04 · experience",
                heading: "A straight line, mostly.",
                items: [
                    { range: "2015 — now",  role: "Senior PHP Developer · AI lead", org: "GALTON Brands s.r.o. (ex ZoneMedia)",
                      body: "Lead backend + the new AI track. Turn static designs into data-driven apps, design REST APIs, optimize databases, and lately — wire MCP servers and agent workflows into the existing Symfony / WordPress stack so the team actually uses them.",
                      bullets: "130+ WordPress sites\n7 React apps\n4 Symfony APIs\nAI / MCP integration across the stack" },
                    { range: "2014 — 2015", role: "IT all-rounder",       org: "TvarPlast s.r.o.",     body: "Sysadmin, web dev and the person you call when nothing prints. Manufacturing IT.", bullets: "" },
                    { range: "~2014",        role: "Web developer",        org: "CMMS s.r.o.",          body: "Built the company site on Symfony. Clean PHP, no shortcuts.", bullets: "" },
                    { range: "~2013",        role: "Software collaborator",org: "Soft-Tech EU s.r.o.",  body: "Java EE + GWT solution for Suzuki Kft. Enterprise automotive software.", bullets: "" }
                ]
            } },
            { type: "cv-projects", fields: {
                section_id: "projects",
                eyebrow: "05 · projects",
                heading: "Selected work.",
                items: [
                    { name: "Hospital Booking System",        blurb: "Backend API + reservation system for a major hospital. Complex scheduling, patient management, real security requirements. Shipped on Kubernetes with a proper CI/CD pipeline.", tags: "Next.js, Symfony, Kubernetes, ArgoCD, Vault", size: "big" },
                    { name: "Europarl Multimedia Centre",     blurb: "Frontend for the European Parliament's media platform. Multilingual, high-traffic, lots of streaming. The kind of place where things have to just work.", tags: "Next.js, React, Jest, Storybook", size: "big" },
                    { name: "Plastic Surgery Clinic System",  blurb: "Full-stack booking + patient management with secure medical data handling.", tags: "React, Symfony, MySQL", size: "small" },
                    { name: "Mystery Shopping Platform",      blurb: "Task management, reporting and analytics for a mystery shopping company.", tags: "React, Symfony, REST API", size: "small" },
                    { name: "Foxconn Intranet Mobile App",    blurb: "Cross-platform internal app for company comms and employee management.", tags: "Flutter, Dart, REST API", size: "small" },
                    { name: "130+ WordPress & 3 Magento stores", blurb: "The biggest chunk of the last decade. Custom themes, custom plugins, performance work on commercial sites that have to convert.", tags: "WordPress, WooCommerce, Magento, PHP", size: "grid" }
                ]
            } },
    { type: "cv-contact", fields: {
        section_id: "contact",
        eyebrow: "06 · contact",
        heading: "Need someone who'll write it once,<br/>write it well, and not ghost you?",
        primary_label: "erik.kubica@gmail.com",
        primary_url: "mailto:erik.kubica@gmail.com",
        secondary_label: "WhatsApp · +421 908 766 133",
        secondary_url: "https://wa.me/421908766133",
        fineprint: "EU B2B · 25 €/h · SEA & EU hours · usually replies within a day"
    } }
]

home_id := 0
existing := nodes.query({ node_type: "page", slug: "home", limit: 1 })
if existing.total == 0 {
    home_node := nodes.create({
        title: "Erik Kubica · CV 2026",
        slug: "home",
        node_type: "page",
        status: "published",
        blocks_data: cv_blocks
    })
    if !is_error(home_node) {
        home_id = home_node.id
        log.info("Curriculum Vitae seed: home page created")
    }
} else {
    home_id = existing.nodes[0].id
    log.info("Curriculum Vitae seed: home page already exists, preserving editor changes")
}

if home_id > 0 {
    settings.set("homepage_node_id", string(home_id))
    log.info("Curriculum Vitae: homepage_node_id set to " + string(home_id))
}

// ─── Navigation Menu ─────────────────────────────────────────
// Anchor-only menu — single-page CV. Seeded once; re-activation preserves
// any editor changes to the menu items.
existing_menu := menus.get("main-nav")
if is_error(existing_menu) {
    menus.upsert({
        slug: "main-nav",
        name: "Primary Navigation",
        items: [
            { label: "about",      url: "#about",    target: "_self" },
            { label: "now",        url: "#now",      target: "_self" },
            { label: "stack",      url: "#stack",    target: "_self" },
            { label: "experience", url: "#xp",       target: "_self" },
            { label: "projects",   url: "#projects", target: "_self" },
            { label: "contact",    url: "#contact",  target: "_self" }
        ]
    })
    log.info("Curriculum Vitae: main-nav menu created")
} else {
    log.info("Curriculum Vitae: main-nav menu already exists, preserving editor changes")
}

log.info("Curriculum Vitae theme initialization complete")
