	{ title: "Mekong hammock",         slug: "photo-10", fields_data: { caption: "mekong hammock",             category: "Landscapes",  color: "green",  tall: false , photo: { url: "theme-asset:gal-mekong-hammock", alt: "photo-10" } } },
	{ title: "Tuan on his bike",       slug: "photo-11", fields_data: { caption: "tuan on his bike",           category: "People",      color: "red",    tall: true  , photo: { url: "theme-asset:gal-tuan-bike", alt: "photo-11" } } },
	{ title: "Egg coffee pour",        slug: "photo-12", fields_data: { caption: "egg coffee pour",            category: "Workshops",   color: "ink",    tall: false , photo: { url: "theme-asset:gal-egg-coffee", alt: "photo-12" } } }
], "default")

// ─── Page Seeding ────────────────────────────────────────────

page_missing := func(slug) {
	r := nodes.query({ node_type: "page", slug: slug, limit: 1 })
	return r.total == 0
}

log.info("Hello Vietnam: checking demo pages...")

home_id := 0
if page_missing("home") {
	home_node := nodes.create({
		title: "Home",
		slug: "home",
		node_type: "page",
		status: "published",
		blocks_data: [
			{ type: "hv-hero", fields: {
				badge_text: "Xin chào! We're Hello Vietnam.",
				heading_line1: "Eat, wander, &amp;",
				heading_accent: "laugh ",
				heading_line2_after: "your way",
				heading_line3_before: "through ",
				heading_underlined: "Vietnam",
				subheading: "Small-group food crawls, mountain loops, and cooking classes — all run by locals who actually live here. No buses. No bullhorns. Just your new favorite country.",
				cta_primary:   { text: "Find Your Adventure", url: "/trips", target: "_self" },
				cta_secondary: { text: "Meet the Crew",       url: "/about", target: "_self" },
				social_proof_strong: "2,400+ travelers",
				social_proof_rest: "· Rated 4.9 on TripAdvisor",
				sticker_text: "100% local-guided"
			} },
			{ type: "hv-categories",    fields: { items: [
				{ title: "Foodie",     tag: { slug: "foodie" },     cta: { text: "Explore", url: "/trips?tag=foodie" },     color: "red",    icon: "fork" },
				{ title: "Adventure",  tag: { slug: "adventure" },  cta: { text: "Explore", url: "/trips?tag=adventure" },  color: "green",  icon: "trail" },
				{ title: "Relaxing",   tag: { slug: "relaxing" },   cta: { text: "Explore", url: "/trips?tag=relaxing" },   color: "yellow", icon: "workshop" },
				{ title: "Family Fun", tag: { slug: "family-fun" }, cta: { text: "Explore", url: "/trips?tag=family-fun" }, color: "ink",    icon: "family" }
			] } },
			{ type: "hv-featured",      fields: { eyebrow: "Featured Experience" } },
			{ type: "hv-how-it-works",  fields: {
				eyebrow: "How it works",
				heading: "Three steps. Zero stress.",
				steps: [
					{ number: "01", title: "Book it",         body: "Pick a trip, fill the Vibe Check, pay half upfront.",                      color: "red" },
					{ number: "02", title: "Pack your bags",  body: "We WhatsApp you everything you need — what to wear, what to leave behind.", color: "yellow" },
					{ number: "03", title: "Eat everything",  body: "Show up hungry. We handle the rest. Bring an empty memory card.",           color: "green" }
				]
			} },
			{ type: "hv-popular-trips", fields: {
				eyebrow: "Our most-booked",
				heading: "Trips travelers can't stop talking about.",
				cta: { text: "See all trips →", url: "/trips" },
				limit: 3
			} },
			{ type: "hv-wall-of-love",  fields: {
				eyebrow: "Wall of love",
				heading: "Bragging rights, straight from our guests.",
				limit: 4
			} },
			{ type: "hv-lead-magnet",   fields: {
				badge_text: "Free · 12-page PDF",
				heading: "The Hanoi Street Food Map.",
				body: "Every bún chả, bánh mì, and egg coffee spot we actually eat at. Numbered, mapped, ranked, and updated every month.",
				input_placeholder: "your@email.com",
				submit_label: "Send me the map",
				image_label: "PDF mockup"
			} }
		]
	})
	if !is_error(home_node) {
		home_id = home_node.id
	}
	log.info("Hello Vietnam seed: home page created")
} else {
	r := nodes.query({ node_type: "page", slug: "home", limit: 1 })
	if r.total > 0 {
		home_id = r.nodes[0].id
	}
}

// Always re-assert the homepage mapping so / resolves to our home node
// rather than any previously-claimed slug from another theme.
if home_id > 0 {
	settings.set("homepage_node_id", string(home_id))
	log.info("Hello Vietnam: homepage_node_id set to " + string(home_id))
}

if page_missing("about") {
	nodes.create({
		title: "About",
		slug: "about",
		node_type: "page",
		status: "published",
		blocks_data: [
			{ type: "hv-about-intro", fields: {
				eyebrow: "About us",
				heading: "We're not a tour company. We're your loud Vietnamese cousins.",
				body_p1: "Hello Vietnam started over a beer in 2016, when Linh realized most tourists were seeing her country through a tinted bus window. Ten years later, we've hand-built 18 trips across Vietnam — all led by people who grew up here.",
				body_p2: "We skip the tourist traps. We pay our guides fairly. We eat lunch on the same tiny plastic stools as our guests.",
				team_photo_caption: "team photo · lunch on plastic stools"
			} },
			{ type: "hv-timeline", fields: {
				eyebrow: "The origin story",
				heading: "From backpackers to local guides.",
				entries: [
					{ year: "2016", body: "Linh quits her bank job. Starts leading food tours for backpacker friends.", color: "red" },
					{ year: "2018", body: "Tuan joins after driving Linh through Ha Giang on a whim. The loop is born.", color: "green" },
					{ year: "2020", body: "Pandemic hits. We pivot to online cooking classes and stay connected.", color: "yellow" },
					{ year: "2022", body: "We open a Hanoi office. Still just a room above a bánh mì shop.", color: "red" },
					{ year: "2026", body: "2,400+ travelers later, we're still on plastic stools.", color: "green" }
				]
			} },
			{ type: "hv-crew-grid", fields: {
