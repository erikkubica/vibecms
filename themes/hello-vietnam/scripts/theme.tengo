// ─── Navigation Menus ────────────────────────────────────────
// Seed / refresh primary and footer navigation on every activation.
// Items use { page: "<slug>" } so they follow the node if an editor
// renames the page's URL — no manual menu edits required.
menus.upsert({
	slug: "main-nav",
	name: "Primary Navigation",
	items: [
		{ label: "Home",    page: "home" },
		{ label: "About",   page: "about" },
		{ label: "Trips",   page: "trips" },
		{ label: "Gallery", page: "gallery" },
		{ label: "Contact", page: "contact" }
	]
})

menus.upsert({
	slug: "footer-nav",
	name: "Footer Navigation",
	items: [
		{ label: "All Trips", page: "trips" },
		{ label: "Gallery",   page: "gallery" },
		{ label: "Our Story", page: "about" },
		{ label: "Contact",   page: "contact" },
		{ label: "Privacy",   page: "legal" }
	]
})
log.info("Hello Vietnam: navigation menus seeded (main-nav, footer-nav)")

log.info("Hello Vietnam theme initialization complete")
