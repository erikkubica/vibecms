			{ type: "hv-values", fields: {
				eyebrow: "What we stand for",
				heading: "Three rules we don't break.",
				items: [
					{ color: "red",    icon: "x",     title: "No tourist traps",   body: "If it's in every guidebook, we're not taking you there. Period." },
					{ color: "yellow", icon: "heart", title: "Supporting locals",  body: "Every vendor we work with is a neighbor. Every guide earns a real wage." },
					{ color: "green",  icon: "leaf",  title: "Always sustainable", body: "Small groups, reusable everything, and trips that leave places better." }
				]
			} },
			{ type: "hv-impact", fields: {
				eyebrow: "Community impact",
				heading: "5% of every booking funds a village school.",
				body: "Since 2019, we've helped build two classrooms and funded 47 scholarships in Ba Be Province. Our partner, the Ma Pi Leng Learning Initiative, is run by former guide Minh.",
				cta: { text: "Read the impact report", url: "/impact", target: "_self" }
			} },
			{ type: "hv-contact-band", fields: {
