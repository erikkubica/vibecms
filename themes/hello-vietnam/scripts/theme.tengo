// theme.tengo — Hello Vietnam Adventures theme entry point.
// Registers node types, taxonomies, seeds demo content (trips, crew, testimonials, gallery),
// and seeds a demo node per public route.

log := import("core/log")
nodetypes := import("core/nodetypes")
taxonomies := import("core/taxonomies")
nodes := import("core/nodes")
filters := import("core/filters")
settings := import("core/settings")
menus := import("core/menus")
core_events := import("core/events")
core_assets := import("core/assets")

log.info("Hello Vietnam theme initializing...")

// ─── Taxonomies ──────────────────────────────────────────────
taxonomies.register({
	slug: "trip_tag",
	label: "Trip tag",
	label_plural: "Trip tags",
	description: "Foodie / Adventure / Relaxing",
	hierarchical: false,
	node_types: ["trip"]
})

taxonomies.register({
	slug: "gallery_category",
	label: "Gallery category",
	label_plural: "Gallery categories",
	description: "Street Food / Landscapes / People / Workshops",
	hierarchical: false,
	node_types: ["gallery_photo"]
})

// ─── Node Types ──────────────────────────────────────────────
nodetypes.register({
	slug: "trip",
	label: "Trip",
	label_plural: "Trips",
	icon: "map",
	description: "A bookable small-group adventure",
	url_prefixes: { en: "trips" },
	field_schema: [
		{ name: "tag",        label: "Tag",               type: "term",     taxonomy: "trip_tag", term_node_type: "trip", help: "Pick a trip tag — managed in Taxonomies." },
		{ name: "duration",   label: "Duration",          type: "text" },
		{ name: "price",      label: "Price (USD)",       type: "number" },
		{ name: "location",   label: "Location",          type: "text" },
		{ name: "rating",     label: "Rating",            type: "number" },
		{ name: "reviews",    label: "Review Count",      type: "number" },
		{ name: "staff_pick", label: "Staff Pick",        type: "checkbox" },
		{ name: "color",      label: "Accent",            type: "text",     help: "red | yellow | green" },
		{ name: "short",      label: "Short Description", type: "textarea" },
		{ name: "hero_image", label: "Hero Image",        type: "image" },
		{ name: "gallery",    label: "Gallery",           type: "repeater",
			sub_fields: [
				{ name: "image",   label: "Image",   type: "image" },
				{ name: "caption", label: "Caption", type: "text"  }
			]
		},
		{ name: "stops",      label: "Stops",             type: "repeater",
			sub_fields: [
				{ name: "title", label: "Stop Title", type: "text" },
				{ name: "brief", label: "Brief",      type: "textarea" }
			]
		},
		{ name: "included",     label: "What's Included",     type: "repeater",
			sub_fields: [ { name: "item", label: "Item", type: "text" } ]
		},
		{ name: "not_included", label: "What's Not Included", type: "repeater",
			sub_fields: [ { name: "item", label: "Item", type: "text" } ]
		},
		{ name: "faqs",         label: "Quick FAQs",          type: "repeater",
			sub_fields: [
				{ name: "q", label: "Question", type: "text" },
				{ name: "a", label: "Answer",   type: "textarea" }
			]
		},
		{ name: "order_form",   label: "Order Form",          type: "form_selector",
			help: "Form rendered in the trip booking sidebar. Defaults to 'trip-order' for seeded trips." }
	],
	taxonomies: ["trip_tag"]
})

// Note: core/terms Tengo module is not yet available — seed trip_tag terms
// (Foodie, Adventure, Relaxing, Family Fun) via admin or MCP core.term.create.
// The /trips filter reads distinct fields_data.tag values directly so the
// filter pills work regardless, but the admin taxonomy page is empty until
// terms are seeded separately.

nodetypes.register({
	slug: "crew_member",
	label: "Crew member",
	label_plural: "Crew",
	icon: "users",
	description: "A Hello Vietnam guide or staff member",
	field_schema: [
		{ name: "role",   label: "Role",      type: "text" },
		{ name: "based",  label: "Based In",  type: "text" },
		{ name: "fun",    label: "Fun Fact",  type: "text" },
		{ name: "color",  label: "Accent",    type: "text", help: "red | yellow | green" },
		{ name: "photo",  label: "Photo",     type: "image" }
	]
})

nodetypes.register({
	slug: "testimonial",
	label: "Testimonial",
	label_plural: "Testimonials",
	icon: "message-circle",
	description: "Traveler testimonial",
	field_schema: [
		{ name: "quote",  label: "Quote",  type: "textarea" },
		{ name: "author", label: "Author", type: "text" },
		{ name: "handle", label: "Handle", type: "text" },
		{ name: "color",  label: "Accent", type: "text", help: "red | yellow | green" },
		{ name: "photo",  label: "Photo",  type: "image" },
		{ name: "trip",   label: "Trip",   type: "node", node_types: ["trip"], help: "Pick the trip this review is about. Leave empty for generic testimonials." }
	]
})

nodetypes.register({
	slug: "gallery_photo",
	label: "Gallery photo",
	label_plural: "Gallery photos",
	icon: "image",
	description: "An image for the public gallery",
	field_schema: [
		{ name: "caption",  label: "Caption",           type: "text" },
		{ name: "category", label: "Category",          type: "text", help: "Street Food | Landscapes | People | Workshops" },
		{ name: "color",    label: "Placeholder Color", type: "text", help: "red | yellow | green | ink" },
		{ name: "tall",     label: "Tall Tile",         type: "checkbox", help: "340px if true, 240px if false" },
		{ name: "photo",    label: "Photo",             type: "image" }
	],
	taxonomies: ["gallery_category"]
})

log.info("Hello Vietnam: 4 custom node types registered")

// ─── Filters ─────────────────────────────────────────────────
filters.add("list_nodes",     "./filters/list_nodes")
filters.add("distinct_field", "./filters/distinct_field")
filters.add("get_node",       "./filters/get_node")
log.info("Hello Vietnam: filters registered (list_nodes, distinct_field, get_node)")

// ─── Site Settings (hv.* namespace) ──────────────────────────
// Seeded once so blocks / partials can read shared values via
// {{index .app.settings "hv.key"}}. Editors override via the admin.
seed_setting := func(key, value) {
	existing := settings.get(key)
	if existing == "" || is_error(existing) {
		settings.set(key, value)
	}
}

seed_setting("hv.site_tagline",       "Small-group, locally-guided adventures across Vietnam. Zero tourist traps, maximum laughter.")
seed_setting("hv.primary_cta_label",  "Find Your Adventure →")
seed_setting("hv.primary_cta_url",    "/trips")
seed_setting("hv.trust_rating",       "4.9")
seed_setting("hv.trust_count",        "2,400+")
seed_setting("hv.trust_platform",     "TripAdvisor")
seed_setting("hv.whatsapp",           "+84 12 3456 7890")
seed_setting("hv.email",              "hello@hellovietnam.travel")
seed_setting("hv.phone",              "+84 24 3333 0000")
seed_setting("hv.address",            "17 Hang Ca, Old Quarter, Hanoi")
seed_setting("hv.social.instagram",   "https://instagram.com/hellovietnamadventures")
seed_setting("hv.social.tiktok",      "https://tiktok.com/@hellovietnam")
seed_setting("hv.social.whatsapp",    "https://wa.me/84123456789")
seed_setting("hv.social.email",       "mailto:hello@hellovietnam.travel")
seed_setting("hv.license",            "Registered tour operator · License #HN-2021-0847")
seed_setting("hv.copyright_owner",    "Hello Vietnam Adventures")
seed_setting("hv.impact_percent",     "5%")
seed_setting("hv.copyright_year",     "2026")
seed_setting("hv.lead_magnet.title",  "The Hanoi Street Food Map.")
seed_setting("hv.lead_magnet.body",   "Every dish worth a detour, every egg-coffee den we actually love, 12 laminated-ready pages. Numbered and sortable by district.")
seed_setting("hv.lead_magnet.cta",    "Send me the map")
log.info("Hello Vietnam: hv.* settings seeded")

// ─── Form Seeding ────────────────────────────────────────────
// Idempotent per-slug upsert via the forms extension's forms:upsert event.
// First-run creates the form; subsequent runs no-op so editor changes survive
// theme re-imports. Pass `force: true` to overwrite.
seed_form := func(spec) {
	core_events.emit("forms:upsert", spec)
}

// Layout HTML lives in themes/hello-vietnam/forms/trip-order.html — full
// theme-styled markup (same .input/.btn/.card classes + data-* hooks the
// original inline form used). Read at activation and shipped to the forms
// extension so the form looks 1:1 with the theme out of the box.
trip_order_layout := core_assets.read("forms/trip-order.html")
if is_error(trip_order_layout) {
	log.warn("Hello Vietnam: failed to read trip-order layout: " + string(trip_order_layout))
	trip_order_layout = ""
}

seed_form({
	slug: "trip-order",
	name: "Trip Booking",
	force: true,
	layout: trip_order_layout,
	settings: {
		success_message: "You're in! Confirmation sent to your inbox.",
		store_ip: true,
		honeypot_enabled: true
	},
	fields: [
		{ id: "first_name", type: "text",     label: "First name",         required: true },
		{ id: "surname",    type: "text",     label: "Surname" },
		{ id: "email",      type: "email",    label: "Email",              required: true },
		{ id: "phone",      type: "tel",      label: "WhatsApp / Phone",   placeholder: "+84 …" },
		{ id: "date",       type: "date",     label: "Trip date" },
		{ id: "adults",     type: "number",   label: "Adults",             default: "2", min: 1 },
		{ id: "kids",       type: "number",   label: "Kids (under 12)",    default: "0", min: 0 },
		{ id: "dietary",    type: "select",   label: "Dietary needs",
			options: [
				{ label: "None",                 value: "none" },
				{ label: "Vegetarian",           value: "vegetarian" },
				{ label: "Vegan",                value: "vegan" },
				{ label: "Gluten-free",          value: "gluten_free" },
				{ label: "Allergies (specify)", value: "allergies" }
			]
		},
		{ id: "vibe",       type: "textarea", label: "The Vibe Check",
			placeholder: "Any specific foods you're dying to try? Or absolutely hate?" }
	]
})
log.info("Hello Vietnam: trip-order form upsert emitted")

// ─── Demo Node Seeding ───────────────────────────────────────
// `default_layout` pins seeded nodes to a specific layout via layout_slug, so
// pages render correctly without manual intervention after theme import.
seed := func(node_type, label, items, default_layout) {
	res := nodes.query({ node_type: node_type, limit: 1 })
	if res.total > 0 {
		log.info("Hello Vietnam seed: " + label + " already exist, skipping")
		return
	}
	log.info("Hello Vietnam seed: creating " + label + "...")
	for item in items {
		item.node_type = node_type
		item.status = "published"
		if !is_undefined(default_layout) && default_layout != "" {
			if is_undefined(item.layout) || item.layout == "" {
				item.layout = default_layout
			}
		}
		nodes.create(item)
	}
	log.info("Hello Vietnam seed: " + string(len(items)) + " " + label + " created")
}

